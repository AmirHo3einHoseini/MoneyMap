<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.moneymap.presentation.splash.SplashFragment"
        android:label="SplashFragment">

        <action
            android:id="@+id/action_splash_to_login"
            app:destination="@+id/loginFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_dashboard"
            app:destination="@+id/dashboardFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.moneymap.presentation.auth.LoginFragment"
        android:label="LoginFragment">
        <action
            android:id="@+id/action_login_to_register"
            app:destination="@id/registerFragment" />
        <action
            android:id="@+id/action_login_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="com.example.moneymap.presentation.auth.RegisterFragment"
        android:label="RegisterFragment">
        <action
            android:id="@+id/action_register_to_dashboard"
            app:destination="@id/dashboardFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_register_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/dashboardFragment"
        android:name="com.example.moneymap.presentation.dashboard.DashboardFragment"
        android:label="DashboardFragment">
        <action
            android:id="@+id/action_dashboard_to_transaction"
            app:destination="@id/transactionFragment" />
        <action
            android:id="@+id/action_dashboard_to_budget"
            app:destination="@id/budgetFragment" />
        <action
            android:id="@+id/action_dashboard_to_add_transaction"
            app:destination="@id/addTransactionFragment" />
        <action
            android:id="@+id/action_dashboard_to_login"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/dashboardFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/transactionFragment"
        android:name=""
        android:label="TransactionFragment">
        <action
            android:id="@+id/action_transaction_to_add"
            app:destination="@id/addTransactionFragment" />
    </fragment>

    <fragment
        android:id="@+id/addTransactionFragment"
        android:name=""
        android:label="AddTransactionFragment" />

    <fragment
        android:id="@+id/budgetFragment"
        android:name="com.example.moneymap.presentation.budget.BudgetFragment"
        android:label="BudgetFragment">
        <action
            android:id="@+id/action_budget_to_set_budget"
            app:destination="@id/setBudgetFragment" />
    </fragment>


    <fragment
        android:id="@+id/setBudgetFragment"
        android:name=""
        android:label="SetBudgetFragment" />


</navigation>

